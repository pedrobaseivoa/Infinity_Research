# ─────────────────────────────────────────────────────────────
# Infinity Research — Environment Variables
# Copy this file to `.env.local` and fill in your own values.
# NEVER commit `.env.local` (it is git-ignored).
# ─────────────────────────────────────────────────────────────

# ── Supabase (required) ──────────────────────────────────────
# Create a free project at https://supabase.com and grab these
# from Project Settings → API.

# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public "anon" key (safe to expose to the browser; protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (SERVER-ONLY, bypasses RLS — never expose to the client!)
# Used by API routes and one-off maintenance scripts.
SUPABASE_SERVICE_ROLE_KEY=

# ── Single-user / self-hosted owner ──────────────────────────
# This app runs in single-user mode: there is NO login screen. The middleware
# automatically signs in as this owner account (creating it on first run).
# SECURITY: access control is network-level only — anyone who can reach the app
# is the owner. Only run it on localhost or a private network you control.
OWNER_EMAIL=owner@infinity.local
OWNER_PASSWORD=change-me-to-a-long-random-string

# ── LLM / Enrichment API keys ────────────────────────────────
# This app is BYOK (Bring Your Own Key). End users normally enter
# their own OpenRouter key in the in-app Settings page, which is
# stored per-user in the database. The variables below are only
# needed for the standalone maintenance scripts in /scripts.

# OpenRouter key for /scripts LLM calls — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional bibliographic enrichment keys (improve rate limits / coverage).
# All three are optional; the pipeline works without them.
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_API_KEY=
CORE_API_KEY=
