# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# dev-only script artifacts (may contain partial API key material / dumps)
/scripts/*-output.txt
/scripts/*-output.json
/scripts/*-results.json

# research data, manuscripts, exports, figures and legacy code — kept locally,
# out of the app repo (see research-data/)
/research-data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
